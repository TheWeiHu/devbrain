{
  "model": "opus",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/local/bin/other-tool hook"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/devbrain/bin/devbrain hook capture"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "guardrail"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/devbrain/bin/devbrain hook gbrain"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/devbrain/bin/devbrain hook response"
          }
        ]
      }
    ]
  },
  "env": {
    "FOO": "bar"
  }
}
