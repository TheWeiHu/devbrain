{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/devbrain/bin/devbrain hook capture"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/devbrain/bin/devbrain hook session-start"
          }
        ]
      }
    ]
  }
}
